---
interface Props {
  /**
   * 'home' — wordmark + WORK·WRITING menu top-left, social links top-right (default).
   * 'internal' — wordmark top-left, simple `Work · Writing` text nav top-right with current section highlighted.
   *
   * The internal variant is used on every page except the home page.
   */
  variant?: 'home' | 'internal';
  /**
   * For variant='internal': which nav item should render as active (ink color vs stone).
   * Allowed values: 'work', 'writing', or undefined (no item active).
   */
  active?: 'work' | 'writing';
}

const { variant = 'home', active } = Astro.props;
---

{variant === 'home' && (
  <header class="site-header site-header--home">
    <div class="site-header__inner">
      <div class="site-header__left">
        <a href="/" class="site-header__wordmark">NZM</a>
        <nav class="site-header__menu" aria-label="Primary navigation">
          <a href="/work">WORK</a>
          <span aria-hidden="true">·</span>
          <a href="/writing">WRITING</a>
        </nav>
      </div>
      <div class="site-header__right">
        <nav class="site-header__social" aria-label="Social links">
          <a href="https://github.com/Nizamohammed" target="_blank" rel="noopener noreferrer">GitHub</a>
          <span aria-hidden="true">·</span>
          <a href="https://linkedin.com/in/nizam-mohammed" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <span aria-hidden="true">·</span>
          <a href="https://x.com/NizamM0hammed" target="_blank" rel="noopener noreferrer">Twitter</a>
        </nav>
      </div>
    </div>
  </header>
)}

{variant === 'internal' && (
  <header class="site-header site-header--internal">
    <div class="site-header__inner">
      <a href="/" class="site-header__wordmark">NZM</a>
      <nav class="site-header__internal-nav" aria-label="Primary navigation">
        <a href="/work" class:list={['site-header__internal-link', { 'is-active': active === 'work' }]}>Work</a>
        <span aria-hidden="true">·</span>
        <a href="/writing" class:list={['site-header__internal-link', { 'is-active': active === 'writing' }]}>Writing</a>
      </nav>
    </div>
  </header>
)}

<style>
  /* Shared */
  .site-header {
    width: 100%;
    border-bottom: 1px solid var(--hairline);
  }
  .site-header__inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 32px 40px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
  }
  .site-header__wordmark {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--ink);
    text-decoration: none;
  }

  /* Home variant */
  .site-header--home .site-header__left {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .site-header__menu {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .site-header__menu a {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--stone);
    text-decoration: none;
    transition: color 200ms ease;
  }
  .site-header__menu a:hover {
    color: var(--ember);
  }
  .site-header__menu span[aria-hidden] {
    color: var(--stone);
    font-size: 12px;
  }
  .site-header__social {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .site-header__social a {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--ink);
    text-decoration: none;
    transition: color 200ms ease;
  }
  .site-header__social a:hover {
    color: var(--ember);
  }
  .site-header__social span[aria-hidden] {
    color: var(--stone);
    font-size: 13px;
  }

  /* Internal variant */
  .site-header--internal .site-header__inner {
    align-items: center;
  }
  .site-header__internal-nav {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .site-header__internal-link {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--stone);
    text-decoration: none;
    transition: color 200ms ease;
  }
  .site-header__internal-link:hover {
    color: var(--ember);
  }
  .site-header__internal-link.is-active {
    color: var(--ink);
  }
  .site-header__internal-nav span[aria-hidden] {
    color: var(--stone);
    font-size: 14px;
  }

  @media (max-width: 640px) {
    .site-header__inner {
      padding: 24px;
    }
    .site-header__social {
      gap: 8px;
    }
    .site-header__social a {
      font-size: 12px;
    }
  }
</style>
