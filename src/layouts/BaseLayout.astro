---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Nizam Mohammed' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body>
    <div class="page-wrapper">
      <Header />
      <main class="page-main">
        <slot />
      </main>
    </div>
    <Footer />
  </body>
</html>

<style is:global>
  /* Layered layout: page-wrapper sits above the fixed footer */
  .page-wrapper {
    position: relative;
    z-index: 2;
    background: var(--paper);
    min-height: 100vh;
    /* Scroll runway — gives the user space to scroll past the wrapper's
       content so the fixed footer is gradually revealed underneath */
    margin-bottom: 100vh;
    display: flex;
    flex-direction: column;
  }

  .page-main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
</style>
