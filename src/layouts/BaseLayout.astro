---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  /** Which header variant to render. Defaults to 'home'. */
  headerVariant?: 'home' | 'internal';
  /** For internal variant: which nav item is active. */
  activeNav?: 'work' | 'writing';
}

const {
  title = 'Nizam Mohammed',
  headerVariant = 'home',
  activeNav,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body>
    <div class="page-wrapper">
      <Header variant={headerVariant} active={activeNav} />
      <main class="page-main">
        <slot />
      </main>
    </div>
    <Footer />
  </body>
</html>

<style is:global>
  .page-wrapper {
    position: relative;
    z-index: 2;
    background: var(--paper);
    min-height: 100vh;
    margin-bottom: 100vh;
    display: flex;
    flex-direction: column;
  }
  .page-main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
</style>
